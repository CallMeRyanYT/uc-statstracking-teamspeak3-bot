# ==============================================================================
# UC Stats Tracking Bot — Environment Configuration
# Copy this file to '.env' and fill in your details.
# Never commit your real .env to source control!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. TeamSpeak 3 ServerQuery Connection
# ------------------------------------------------------------------------------
# The IP or hostname of your TS3 server.
# - If running the bot via Docker on the SAME PC as the TS3 server:
#     TS3_HOST=host.docker.internal
# - If running without Docker on the same PC:
#     TS3_HOST=127.0.0.1
# - If on a separate machine, use the server's LAN IP or public IP.
TS3_HOST=host.docker.internal

# ServerQuery TCP port (default 10011 — never the voice port 9987)
TS3_QUERY_PORT=10011

# ServerQuery credentials — found in your TS3 server's query_ip_whitelist.txt
# and the initial server log when it first starts ("ServerAdmin password: ...")
TS3_QUERY_USER=serveradmin
TS3_QUERY_PASS=your_serverquery_password_here

# Virtual server ID (usually 1 for a single-server install)
TS3_SERVER_ID=1

# The display name the bot's query connection uses (visible in server admin tools)
TS3_BOT_NICKNAME=UC Stats Bot

# ------------------------------------------------------------------------------
# 2. Channel to "join" (bot will post command replies here)
# ------------------------------------------------------------------------------
TS3_CHANNEL_NAME=Stalking Room
TS3_CHANNEL_PASS=1337

# ------------------------------------------------------------------------------
# 3. Discord Webhook (for automatic leaderboard posts)
# ------------------------------------------------------------------------------
# Your Discord webhook URL — the bot will post reports here automatically.
# Leave as-is to use the pre-configured UC webhook, or replace with your own.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1521648074139762829/U0axTr9CMsHLZEQ230HHTMk1kadu5whbBzqYbZkW8xmzQzsu6las6CkBNia9e7eiRc5h

# Set to "true" to also post join/leave events to Discord
JOIN_LEAVE_WEBHOOK=false

# ------------------------------------------------------------------------------
# 4. Tracking Behaviour
# ------------------------------------------------------------------------------
# How long (in minutes) a user must be in "away" status before time is paused.
# Set to 5 to match the server rules (toggle away ≥5 min = paused).
AFK_AWAY_THRESHOLD_MINUTES=5

# Comma-separated TS3 channel IDs to EXCLUDE from tracking (e.g. AFK rooms).
# Leave blank to track all channels.
EXCLUDED_CHANNELS=

# Comma-separated bot/query client nicknames to never track.
BOT_NICKNAMES=UC Stats Bot,serveradmin

# Polling interval in milliseconds (60000 = every 1 minute)
POLL_INTERVAL_MS=60000

# ------------------------------------------------------------------------------
# 5. Web Dashboard
# ------------------------------------------------------------------------------
# HTTP port for the web leaderboard dashboard
WEB_PORT=3000

# Timezone for cron job display labels (e.g. UTC, Europe/Helsinki, America/New_York)
TZ=UTC

# ------------------------------------------------------------------------------
# 6. Command Prefix
# ------------------------------------------------------------------------------
COMMAND_PREFIX=!
