# ==============================================================================
# UC Stats Tracking Bot - Environment Configuration
# Copy this file to ".env" and fill in your details.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. TeamSpeak 3 ServerQuery Connection
# ------------------------------------------------------------------------------
# If Docker and TS3 run on the same PC, use host.docker.internal.
TS3_HOST=host.docker.internal

# ServerQuery TCP port. Default TeamSpeak ServerQuery is 10011.
TS3_QUERY_PORT=10011

# ServerQuery credentials from your TS3 server logs / ServerQuery account.
TS3_QUERY_USER=serveradmin
TS3_QUERY_PASS=your_serverquery_password_here

# Virtual server ID and normal TS3 voice port.
TS3_SERVER_ID=1
TS3_SERVER_PORT=9987

# Query connection timeout and visible query nickname.
TS3_CONNECT_TIMEOUT_MS=10000
TS3_BOT_NICKNAME=UC Stats Bot

# Server group IDs allowed to unlock dashboard editing after UID verification.
# TeamSpeak's default Server Admin group is commonly 6; confirm yours in TS3.
TS3_ADMIN_GROUP_IDS=6

# ------------------------------------------------------------------------------
# 2. Tracking Behaviour
# ------------------------------------------------------------------------------
# How long a user must be away before active time pauses.
AFK_AWAY_THRESHOLD_MINUTES=5

# Comma-separated TS3 channel IDs to skip, for example AFK rooms.
EXCLUDED_CHANNELS=

# Comma-separated bot/query client nicknames to never track.
BOT_NICKNAMES=UC Stats Bot,serveradmin,UC Music Bot,Admonus

# Polling interval in milliseconds. 60000 = every 1 minute.
POLL_INTERVAL_MS=60000

# ------------------------------------------------------------------------------
# 3. Discord Statistics
# ------------------------------------------------------------------------------
# Keep this secret. Leave blank to disable Discord reports.
DISCORD_WEBHOOK_URL=

# Automatic report frequency, from 5 to 1440 minutes. Clock-aligned (:00 for 60).
DISCORD_REPORT_INTERVAL_MINUTES=60

# Public website included in Discord reports.
PUBLIC_DASHBOARD_URL=https://uct.aquaweb.cc/

# ------------------------------------------------------------------------------
# 4. Web Dashboard
# ------------------------------------------------------------------------------
# Port inside the container.
WEB_PORT=3000

# Port exposed on your Windows PC.
HOST_WEB_PORT=3000

# Local-only admin API. Docker publishes this on 127.0.0.1 only.
ADMIN_PORT=3001
HOST_ADMIN_PORT=3001

# Timezone for reset labels/logs.
TZ=UTC
